# Copy to .env and fill in. docker compose reads this for ${VAR} substitution.

# --- Public address ---
# ":80"  -> serve HTTP on the VM's external IP (quick start, no domain needed)
# a domain (e.g. app.secureyourhacks.com) -> Caddy gets an HTTPS cert automatically
SITE_ADDRESS=:80

# --- Vertex AI (Gemini) for Ask SecureBot + Risk Agent ---
# The service-account key file (gcp-vertex-sa.json) is mounted by docker-compose.
GOOGLE_CLOUD_PROJECT=mlops-487010
GOOGLE_CLOUD_LOCATION=us-central1

# --- ElevenLabs (Phishing Drill voice agent) ---
ELEVENLABS_AGENT_ID=
ELEVENLABS_API_KEY=

# --- Lead capture (all optional) ---
LEAD_TO_EMAIL=care@secureyourhacks.com
RESEND_API_KEY=
LEAD_WEBHOOK_URL=
